<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 基础背景 ===== -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#f6f8fa" />
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#e1e4e8" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#f0f2f5" />

    <!-- ===== 边框 ===== -->
    <SolidColorBrush x:Key="BorderBrush" Color="#d0d7de" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#b8c0c8" />

    <!-- ===== 文字 ===== -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#24292f" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#57606a" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#8b949e" />

    <!-- ===== 强调色（橙色） ===== -->
    <SolidColorBrush x:Key="AccentBrush" Color="#c97d31" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#d4853a" />
    <!-- 半透明强调色 Alpha=26 -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="#26c97d31" />

    <!-- ===== 辅助强调色（蓝） ===== -->
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#2563eb" />

    <!-- ===== 扩展强调色 ===== -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#16a34a" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#dc2626" />

    <!-- ===== 滚动条专用 ===== -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#ffffff" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#d0d7de" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#b8c0c8" />

</ResourceDictionary>