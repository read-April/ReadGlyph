<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 基础背景 ===== -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#14181c" />
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#1e2329" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#262d35" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1a1f25" />

    <!-- ===== 边框 ===== -->
    <SolidColorBrush x:Key="BorderBrush" Color="#333c46" />
    <SolidColorBrush x:Key="BorderLightBrush" Color="#4a5563" />

    <!-- ===== 文字 ===== -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#eaeef3" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#a0aebb" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#6a7a8a" />

    <!-- ===== 强调色（橙色） ===== -->
    <SolidColorBrush x:Key="AccentBrush" Color="#d4853a" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#e3944a" />
    <!-- 半透明强调色（用于选中项背景） Alpha=26 约等于 15% 不透明度 -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="#26d4853a" />

    <!-- ===== 辅助强调色（蓝） ===== -->
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#5294d9" />

    <!-- ===== 扩展强调色 ===== -->
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#4da85c" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#d94a5a" />

    <!-- ===== 滚动条专用 ===== -->
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="#1e2329" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#333c46" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#4a5563" />

</ResourceDictionary>