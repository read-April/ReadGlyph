<UserControl x:Class="ReadGlyph.Views.Dialogs.AlertDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" Padding="24">
        <StackPanel>
            <!-- 标题 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="⚠" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                <TextBlock x:Name="TxtTitle" Text="提示" FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <!-- 消息 -->
            <TextBlock x:Name="TxtMessage" Text="" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,20" />
            <!-- 确定按钮 -->
            <Button x:Name="BtnOk" Content="确定"
                    Style="{StaticResource PrimaryButton}"
                    Width="80" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
