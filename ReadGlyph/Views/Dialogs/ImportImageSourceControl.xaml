<UserControl x:Class="ReadGlyph.Views.Dialogs.ImportImageSourceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ReadGlyph.Helpers"
             mc:Ignorable="d"
             Width="550" Height="280"
             d:DesignHeight="280" d:DesignWidth="550">
    <Border Style="{StaticResource CardBorder}" Padding="28,24">
        <StackPanel>
            <TextBlock Text="🖼️ 导入图片源" FontSize="18" FontWeight="Medium" Margin="0,0,0,12">
                <Run Foreground="{StaticResource TextMutedBrush}" FontSize="13" FontWeight="Normal" Text=" 资源库" />
            </TextBlock>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,18" />

            <!-- 图片显示名称 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="图片显示名称" Style="{StaticResource LabelStyle}" />
                <TextBox x:Name="TxtDisplayName" helpers:TextBoxHelper.PlaceholderText="icon_home" />
            </StackPanel>

            <!-- 图片文件 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="图片文件" Style="{StaticResource LabelStyle}">
                    <Run Foreground="{StaticResource AccentBrush}" Text=" *" />
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtImageFile"
                             helpers:TextBoxHelper.PlaceholderText="home.png" />
                    <Button Grid.Column="2" x:Name="BtnPickImageFile"
                            Style="{StaticResource FilePickerButton}"
                            ToolTip="从文件系统选择 .png / .jpg / .bmp 图片文件"
                            Click="BtnPickImageFile_Click" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="支持 " FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".png" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".jpg" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".bmp" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".gif" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".tga" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Border Background="{StaticResource BackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="2,0" Margin="2,0">
                        <TextBlock Text=".webp" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource {x:Type Button}}" Margin="0,0,10,0" />
                <Button Content="导入" x:Name="BtnImport" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>