<UserControl x:Class="ReadGlyph.Views.Dialogs.AboutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="400">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" Padding="24" CornerRadius="8">
        <StackPanel>
            <!-- 标题栏：关于 + X 关闭 -->
            <DockPanel Margin="0,0,0,16">
                <Button DockPanel.Dock="Right"
                        Content="✕" FontSize="14"
                        Width="32" Height="32" Padding="0"
                        Cursor="Hand"
                        Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <TextBlock Text="{TemplateBinding Content}"
                                                       Foreground="{TemplateBinding Foreground}"
                                                       FontSize="{TemplateBinding FontSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <TextBlock Text="关于 ReadGlyph" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Logo 图标 -->
            <Viewbox Height="64" Width="256" Margin="0,0,0,12" HorizontalAlignment="Left">
                <Canvas Width="900" Height="240">
                    <!-- 芯片外框 -->
                    <Rectangle Canvas.Left="50" Canvas.Top="40"
                               Width="160" Height="160" RadiusX="12" RadiusY="12"
                               Stroke="{DynamicResource AccentBrush}" StrokeThickness="6"
                               Fill="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center" />
                    <!-- 像素 G -->
                    <Rectangle Canvas.Left="90" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="118" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="146" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="90" Canvas.Top="108" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="146" Canvas.Top="108" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="90" Canvas.Top="136" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <Rectangle Canvas.Left="118" Canvas.Top="136" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                    <!-- ReadGlyph -->
                    <TextBlock Canvas.Left="260" Canvas.Top="12"
                               FontFamily="Segoe UI" FontSize="96" FontWeight="Black"
                               Foreground="{DynamicResource TextPrimaryBrush}">
                        <Run Foreground="{DynamicResource AccentBrush}">R</Run>ead<Run Foreground="{DynamicResource AccentBrush}">G</Run>lyph
                    </TextBlock>
                    <!-- 描述语 -->
                    <TextBlock Canvas.Left="260" Canvas.Top="138"
                               FontFamily="Segoe UI" FontSize="50"
                               Foreground="{DynamicResource TextMutedBrush}">
                        字体 · 图片 · 资产工坊
                    </TextBlock>
                </Canvas>
            </Viewbox>

            <!-- 分隔线 -->
            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,12" />

            <!-- 版本 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="版本：" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Width="60" />
                <TextBlock x:Name="TxtVersion" Text="v1.0.0" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- 描述 -->
            <TextBlock Text="嵌入式开发的取模工具，支持将字体和图片转换为 C 语言数组文件。"
                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,6,0,12" />

            <!-- 分隔线 -->
            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,0,0,12" />

            <!-- 邮箱地址 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="邮箱：" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Width="60" />
                <TextBlock FontSize="12" Foreground="{DynamicResource AccentSecondaryBrush}" Cursor="Hand"
                           MouseLeftButtonDown="EmailLink_Click"
                           TextDecorations="Underline">
                    yu_april@qq.com
                </TextBlock>
            </StackPanel>

            <!-- 开源地址 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="仓库：" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Width="60" />
                <TextBlock FontSize="12" Foreground="{DynamicResource AccentBrush}" Cursor="Hand"
                           MouseLeftButtonDown="RepoLink_Click"
                           TextDecorations="Underline">
                    https://github.com/read-April/ReadGlyph
                </TextBlock>
            </StackPanel>

            <!-- 反馈 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="反馈：" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Width="60" />
                <TextBlock Text="通过 Issues 或 邮箱 提交问题与建议" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
