<UserControl x:Class="ReadGlyph.Views.Dialogs.CreateImageAssetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="550" Height="450"
             d:DesignHeight="450" d:DesignWidth="550">
    <Border Style="{StaticResource CardBorder}" Padding="28,24">
        <StackPanel>
            <TextBlock Text="🖼️ 导入图片资产" FontSize="18" FontWeight="Medium" Margin="0,0,0,12">
                <Run Foreground="{StaticResource TextMutedBrush}" FontSize="13" FontWeight="Normal" Text=" 当前项目：智能手表" />
            </TextBlock>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,18" />

            <!-- 图片源 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="图片源" Style="{StaticResource LabelStyle}">
                    <Run Foreground="{StaticResource AccentBrush}" Text=" *" />
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="CmbImageSource">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2" x:Name="BtnPickImage"
                            Style="{StaticResource FilePickerButton}"
                            ToolTip="从文件系统导入 .png / .jpg / .bmp 图片"
                            Click="BtnPickImage_Click" />
                </Grid>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    从资源库选择或点击 ⋯ 导入新图片文件
                </TextBlock>
            </StackPanel>

            <!-- 颜色格式 + 抖动 -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="颜色格式" Style="{StaticResource LabelStyle}" />
                    <ComboBox x:Name="CmbFormat" SelectedIndex="1">
                        <ComboBoxItem Content="RGB565（16位，无透明）" />
                        <ComboBoxItem Content="RGB888（24位）" />
                        <ComboBoxItem Content="ARGB8888（32位）" />
                        <ComboBoxItem Content="I1（1位单色）" />
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="抖动处理（Dither）" Style="{StaticResource LabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ToggleButton x:Name="TglDither" IsChecked="True"
                                      Style="{StaticResource {x:Type ToggleButton}}" />
                        <TextBlock x:Name="TxtDitherState" Text="开启" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                    </StackPanel>
                    <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                        提升低位深图片的显示质量
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- 导出格式 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="导出格式" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CmbExportFormat" SelectedIndex="0" Margin="0,4,0,0">
                    <ComboBoxItem Content="LVGL 9.x（标准）" />
                </ComboBox>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    LVGL 9.x：输出 lv_image_dsc_t 结构，可直接传给 lv_image_set_src()
                </TextBlock>
            </StackPanel>

            <!-- 输出文件名/目录 -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="输出文件名" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtOutputName" Text="image" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="输出目录（相对路径）" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtOutputDir" Text="images/" />
                </StackPanel>
            </Grid>

            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource {x:Type Button}}" Margin="0,0,10,0" />
                <Button Content="生成图片" x:Name="BtnGenerate" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>