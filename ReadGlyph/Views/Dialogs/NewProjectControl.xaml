<UserControl x:Class="ReadGlyph.Views.Dialogs.NewProjectControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:ReadGlyph.Helpers"
             mc:Ignorable="d"
             Width="550" Height="320"
             d:DesignHeight="320" d:DesignWidth="550">
    <Border Style="{StaticResource CardBorder}" Padding="28,24">
        <StackPanel>
            <TextBlock x:Name="TxtTitle" Text="📁 新建项目" FontSize="18" FontWeight="Medium" Margin="0,0,0,16" />
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,18" />

            <!-- 项目名称 -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="项目名称" Style="{StaticResource LabelStyle}">
                    <Run Foreground="{StaticResource AccentBrush}" Text=" *" />
                </TextBlock>
                <TextBox x:Name="TxtName" helpers:TextBoxHelper.PlaceholderText="如：智能手表" />
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    将作为 Data\projects\ 下的项目目录名，不可重复
                </TextBlock>
            </StackPanel>

            <!-- 项目根目录 -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="项目根目录" Style="{StaticResource LabelStyle}">
                    <Run Foreground="{StaticResource AccentBrush}" Text=" *" />
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtProjectPath" helpers:TextBoxHelper.PlaceholderText="./lvgl_project/ui/" />
                    <Button Grid.Column="2" x:Name="BtnPickFolder"
                            Style="{StaticResource FilePickerButton}"
                            ToolTip="浏览选择项目目录"
                            Click="BtnPickFolder_Click" />
                </Grid>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    用于显示资产输出路径，不会实际创建或操作目录
                </TextBlock>
            </StackPanel>

            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource {x:Type Button}}" Margin="0,0,10,0" />
                <Button x:Name="BtnConfirm" Content="创建" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>