<UserControl x:Class="ReadGlyph.Views.Dialogs.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="420" MinHeight="140">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1" Padding="24">
        <StackPanel>
            <!-- 标题 -->
            <TextBlock x:Name="TxtTitle" Text="确认操作" FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       Margin="0,0,0,12" />
            <!-- 消息 -->
            <TextBlock x:Name="TxtMessage" Text="" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,20" />
            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource {x:Type Button}}"
                        Width="80" Margin="0,0,10,0" />
                <Button x:Name="BtnConfirm" Content="确定"
                        Style="{StaticResource PrimaryButton}" Width="80" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
