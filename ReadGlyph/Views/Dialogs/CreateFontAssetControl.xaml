<UserControl x:Class="ReadGlyph.Views.Dialogs.CreateFontAssetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="550" Height="580"
             d:DesignHeight="580" d:DesignWidth="550">
    <Border Style="{StaticResource CardBorder}" Padding="28,24">
        <StackPanel>
            <TextBlock Text="✏️ 创建字体资产" FontSize="18" FontWeight="Medium" Margin="0,0,0,12">
                <Run Foreground="{StaticResource TextMutedBrush}" FontSize="13" FontWeight="Normal" Text=" 当前项目：智能手表" />
            </TextBlock>
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,18" />

            <!-- 字体源 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="字体源" Style="{StaticResource LabelStyle}">
                    <Run Foreground="{StaticResource AccentBrush}" Text=" *" />
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="CmbFontSource">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="2" x:Name="BtnPickFont"
                            Style="{StaticResource FilePickerButton}"
                            ToolTip="从文件系统导入 .ttf / .otf / .ttc 字体"
                            Click="BtnPickFont_Click" />
                </Grid>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    从资源库选择或点击 ⋯ 导入新字体文件
                </TextBlock>
            </StackPanel>

            <!-- 字号 / 位深度 -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="字号 (px)" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtSize" Text="16" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="位深度 (bpp)" Style="{StaticResource LabelStyle}" />
                    <ComboBox x:Name="CmbBpp" SelectedIndex="2">
                        <ComboBoxItem Content="1 bpp" />
                        <ComboBoxItem Content="2 bpp" />
                        <ComboBoxItem Content="4 bpp（推荐）" />
                        <ComboBoxItem Content="8 bpp" />
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- 导出格式 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="导出格式" Style="{StaticResource LabelStyle}" />
                <ComboBox x:Name="CmbExportFormat" SelectedIndex="0" Margin="0,4,0,0">
                    <ComboBoxItem Content="LVGL 9.x（标准）" />
                </ComboBox>
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    LVGL 9.x：输出 lv_font_t 结构，可直接传给 lv_style_set_text_font()
                </TextBlock>
            </StackPanel>

            <!-- 字符集 -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Text="字符集" Style="{StaticResource LabelStyle}" />
                <!-- ASCII 开关 -->
                <CheckBox x:Name="ChkIncludeAscii" IsChecked="True" Margin="0,6,0,4"
                          Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                    <TextBlock>
                        包含 ASCII 可打印字符
                        <Run Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                             Text="（空格、数字、大小写字母、常用符号等 95 个字符）" />
                    </TextBlock>
                </CheckBox>
                <!-- 自定义字符 -->
                <TextBlock Text="额外字符（可选）" Style="{StaticResource LabelStyle}"
                           Margin="0,6,0,0" FontSize="11" />
                <TextBox x:Name="TxtCustomGlyphs"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="50"
                         FontFamily="Consolas" FontSize="12" />
                <TextBlock Margin="0,4,0,0" FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                    直接输入需要的字符，如中文、日文、特殊符号等
                </TextBlock>
            </StackPanel>

            <!-- 输出文件名/目录 -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="输出文件名" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtOutputName" Text="font_16px" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="输出目录（相对路径）" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TxtOutputDir" Text="fonts/" />
                </StackPanel>
            </Grid>

            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource {x:Type Button}}" Margin="0,0,10,0" />
                <Button Content="生成字体" x:Name="BtnGenerate" Style="{StaticResource PrimaryButton}" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>