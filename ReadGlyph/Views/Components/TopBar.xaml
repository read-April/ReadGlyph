<UserControl x:Class="ReadGlyph.Views.Components.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="54" Width="1200">
    <Border Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
        <DockPanel>
            <!-- 右侧：关于 + 主题切换 -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,10,0">

            <!-- 主题切换按钮 -->
                <Button
                    x:Name="BtnThemeToggle"
                    Width="36" Height="36"
                    Margin="0,4,20,4"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="切换深色/浅色主题"
                    Click="BtnThemeToggle_Click">
                    <!-- 默认浅色主题 → 显示月亮图标（点击切深色） -->
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <!-- 外边框圆环（仅月亮模式显示） -->
                            <Ellipse x:Name="IconBorder" Canvas.Left="1" Canvas.Top="1"
                                     Width="22" Height="22"
                                     Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                     Fill="Transparent" />
                            <!-- 太阳：圆 + 8 条射线 -->
                            <Path x:Name="IconSun"
                              Stroke="{DynamicResource AccentBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Visibility="Collapsed">
                                <Path.Data>
                                    <GeometryGroup FillRule="Nonzero">
                                        <EllipseGeometry Center="12,12" RadiusX="5" RadiusY="5" />
                                        <PathGeometry Figures="M12,1v2 M12,21v2
                                              M4.22,4.22l1.42,1.42 M18.36,18.36l1.42,1.42
                                              M1,12h2 M21,12h2
                                              M4.22,19.78l1.42-1.42 M18.36,5.64l1.42-1.42" />
                                    </GeometryGroup>
                                </Path.Data>
                            </Path>
                            <!-- 月亮 -->
                            <Path x:Name="IconMoon"
                                Fill="{DynamicResource AccentBrush}"
                                Visibility="Visible">
                                <Path.Data>
                                    <PathGeometry Figures="M17.6,16.1 A7,7 0 1,1 7.9,6.4 a9,9 0 0,0 9.7,9.7z" />
                                </Path.Data>
                            </Path>
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- 关于按钮 -->
                <Button
                    x:Name="BtnAbout"
                    Margin="0,4,20,4"
                    Width="36" Height="36"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Cursor="Hand"
                    ToolTip="关于 ReadGlyph"
                    Click="BtnAbout_Click"> 
                    <Viewbox Width="32" Height="32">
                        <Canvas Width="1024" Height="1024">
                            <Path Fill="{DynamicResource AccentBrush}">
                                <Path.Data>
                                    <PathGeometry Figures="M469.3,597.3 v-85.3 h-42.7 v-85.3 h128 v170.7 h42.7 v85.3 h-170.7 v-85.3 h42.7z M512,853.3 c-187.7,0 -341.3,-153.6 -341.3,-341.3 s153.6,-341.3 341.3,-341.3 S853.3,324.3 853.3,512 699.7,853.3 512,853.3z M512,768 c140.8,0 256,-115.2 256,-256 S652.8,256 512,256 256,371.2 256,512 371.2,768 512,768z M554.7,298.7 v85.3 h-85.3 V298.7 h85.3z" />
                                </Path.Data>
                            </Path>
                        </Canvas>
                    </Viewbox>
                </Button>

            </StackPanel>

            <!-- 左侧：Logo + 应用名 -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                <!-- 图标 + 字体 Logo（SVG → XAML，900×240 对应 viewBox "0 0 900 240"） -->
                <Viewbox Height="48" Width="180">
                    <Canvas Width="900" Height="240">
                        <!-- 芯片外框（rx=12, stroke=6，匹配 SVG） -->
                        <Rectangle Canvas.Left="50" Canvas.Top="40"
                                   Width="160" Height="160" RadiusX="12" RadiusY="12"
                                   Stroke="{DynamicResource AccentBrush}" StrokeThickness="6"
                                   Fill="Transparent" />
                        <!-- 像素 G（7 个方块，24×24, rx=4） -->
                        <Rectangle Canvas.Left="90" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="118" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="146" Canvas.Top="80" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="90" Canvas.Top="108" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="146" Canvas.Top="108" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="90" Canvas.Top="136" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <Rectangle Canvas.Left="118" Canvas.Top="136" Width="24" Height="24" RadiusX="4" RadiusY="4" Fill="{DynamicResource AccentBrush}" />
                        <!-- ReadGlyph（R、G 橙色高亮，font-size:96, font-weight:900） -->
                        <TextBlock Canvas.Left="260" Canvas.Top="12"
                                   FontFamily="Segoe UI" FontSize="96" FontWeight="Black"
                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Run Foreground="{DynamicResource AccentBrush}">R</Run>ead<Run Foreground="{DynamicResource AccentBrush}">G</Run>lyph
                        </TextBlock>
                        <!-- 描述语（font-size:40，匹配 SVG） -->
                        <TextBlock Canvas.Left="260" Canvas.Top="138"
                                   FontFamily="Segoe UI" FontSize="50"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Top">
                            字体 · 图片 · 资产工坊
                        </TextBlock>
                    </Canvas>
                </Viewbox>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
