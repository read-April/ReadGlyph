<Window x:Class="ReadGlyph.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReadGlyph"
        xmlns:vm="clr-namespace:ReadGlyph.ViewModels"
        xmlns:dialogs="clr-namespace:ReadGlyph.Views.Dialogs"
        xmlns:components="clr-namespace:ReadGlyph.Views.Components"
        xmlns:conv="clr-namespace:ReadGlyph.Converters"
        mc:Ignorable="d"
        Title="ReadGlyph — 字体与图片资产工坊" Height="800" Width="1200"
        Icon="/Resources/fac.ico"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />
        <conv:SourceIdToImageConverter x:Key="SourceIdToImageConverter" />
        <conv:SourceIdToFontNameConverter x:Key="SourceIdToFontNameConverter" />
    </Window.Resources>
    <Grid>
        <!-- ===== 主布局 ===== -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部栏：Logo + 主题切换 -->
            <components:TopBar Grid.Row="0" x:Name="TopBarCtrl" />

            <!-- 中间：主工作区 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 项目工具栏 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="项目：" VerticalAlignment="Center" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0" />
                            <ComboBox x:Name="CmbProjects" Width="177"
                                      ItemsSource="{Binding ProjectNames}"
                                      SelectedItem="{Binding SelectedProject}" />
                        </StackPanel>
                        <TextBox Grid.Column="2" Margin="10 0 0 0" x:Name="TxtProjectPath"
                                 Text="{Binding SelectedProjectPath, FallbackValue='未选择项目'}" IsEnabled="False"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="4" Orientation="Horizontal">
                            <Button x:Name="BtnNewProject"
                                    Content="➕ 创建项目"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnNewProject_Click" />
                            <Button x:Name="BtnEditProject"
                                    Content="✏️ 编辑"
                                    Style="{StaticResource {x:Type Button}}"
                                    Margin="10,0,0,0"
                                    Click="BtnEditProject_Click" />
                            <Button x:Name="BtnDeleteProject"
                                    Content="🗑 删除项目"
                                    Style="{StaticResource {x:Type Button}}"
                                    Margin="10,0,0,0"
                                    Click="BtnDeleteProject_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 内容区：左侧资源库 + 右侧工作区 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="160" MaxWidth="420" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 拖拽分隔条 -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="Transparent" Cursor="SizeWE"
                                  ShowsPreview="False" />

                    <!-- 左侧：资源库导航 -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource SecondaryBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,1,0"
                            Padding="0,12">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      PanningMode="VerticalOnly">
                        <StackPanel>
                            <TextBlock Text="资源库" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       Margin="16,0,0,8" />
                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"
                                       Margin="12,0,12,6" />

                            <!-- 字体库 -->
                            <Border Background="Transparent" Padding="16,6" MinHeight="34" Cursor="Hand"
                                    MouseLeftButtonDown="ToggleFontLib_Click">
                                <DockPanel>
                                    <Button x:Name="BtnAddFont" Width="22" Height="22" Padding="0"
                                            DockPanel.Dock="Right"
                                            Content="+" FontSize="15" FontWeight="Bold"
                                            Cursor="Hand" ToolTip="导入字体源"
                                            Click="BtnAddFont_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Template>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="bg" Background="Transparent" CornerRadius="2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background"
                                                                Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="FontLibArrow" Text="▶" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="字体库" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- 子项：仅展开时显示 -->
                            <StackPanel x:Name="FontLibSubItems" Visibility="Collapsed">
                                <TextBlock x:Name="TxtImportFontHint" Text="   📤 导入字体源" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Padding="16,4" Cursor="Hand"
                                           MouseLeftButtonDown="ImportFontSource_Click"
                                           Visibility="{Binding FontSources.Count, Converter={StaticResource ZeroToVisibleConverter}}" />
                                <ItemsControl ItemsSource="{Binding FontSources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="16,0,16,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="12" Cursor="Hand"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Padding="4,3,8,3"
                                                           MaxWidth="200"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FilePath}" />
                                                <Button Grid.Column="1" Content="✕" FontSize="10"
                                                        Padding="4,0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Background="Transparent"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="DeleteFontSource_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="   （暂无字体源）" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Padding="16,3"
                                           Visibility="{Binding FontSources.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Visible}" />
                            </StackPanel>

                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"
                                       Margin="12,4,12,4" />

                            <!-- 图片库 -->
                            <Border Background="Transparent" Padding="16,6" MinHeight="34" Cursor="Hand"
                                    MouseLeftButtonDown="ToggleImageLib_Click">
                                <DockPanel>
                                    <!-- 右侧 + 按钮（悬停行才显示） -->
                                    <Button x:Name="BtnAddImage" Width="22" Height="22" Padding="0"
                                            DockPanel.Dock="Right"
                                            Content="+" FontSize="15" FontWeight="Bold"
                                            Cursor="Hand" ToolTip="导入图片源"
                                            Click="BtnAddImage_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Template>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border x:Name="bg" Background="Transparent" CornerRadius="2">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bg" Property="Background"
                                                                Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="White" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="ImageLibArrow" Text="▶" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock Text="图片库" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <!-- 子项：仅展开时显示 -->
                            <StackPanel x:Name="ImageLibSubItems" Visibility="Collapsed">
                                <TextBlock x:Name="TxtImportImageHint" Text="   📤 导入图片源" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Padding="16,4" Cursor="Hand"
                                           MouseLeftButtonDown="ImportImageSource_Click"
                                           Visibility="{Binding ImageSources.Count, Converter={StaticResource ZeroToVisibleConverter}}" />
                                <ItemsControl ItemsSource="{Binding ImageSources}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="16,0,16,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="12" Cursor="Hand"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Padding="4,3,8,3"
                                                           MaxWidth="200"
                                                           Text="{Binding DisplayName}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FilePath}" />
                                                <Button Grid.Column="1" Content="✕" FontSize="10"
                                                        Padding="4,0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Background="Transparent"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Click="DeleteImageSource_Click" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="   （暂无图片源）" FontSize="11"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Padding="16,3"
                                           Visibility="{Binding ImageSources.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Visible}" />
                            </StackPanel>
                        </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- 右侧：工作区 -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Margin="0,0,16,0"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- 字体资产 -->
                            <Border Grid.Row="0"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Padding="16 0 16 0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 标题栏 -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button x:Name="BtnCreateFont"
                                                    Content="➕ 创建字体"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="BtnCreateFont_Click" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="项目字体资产" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock x:Name="TxtFontAssetCount"
                                                       Text="{Binding FontAssetCount}" FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="8,0,0,0" />
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- 表格 -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- 表头 -->
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" Padding="8,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="66" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="90" />
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="预览" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                                <TextBlock Grid.Column="1" Text="文件" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="6,0,0,0" />
                                                <TextBlock Grid.Column="4" Text="导出格式" FontSize="11"
                                                            Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="2" Text="字号" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="位深" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                
                                                           
                                                <TextBlock Grid.Column="5" Text="字形字符" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="6,0,0,0" />
                                                <TextBlock Grid.Column="6" Text="操作" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <!-- 空状态 -->
                                        <StackPanel x:Name="FontEmptyState" Grid.Row="1"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="⚠ 暂无字体资产" FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="点击「创建字体」从资源库生成字体.c文件" FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0" />
                                        </StackPanel>

                                        <!-- 数据行容器（有数据时显示） -->
                                        <ScrollViewer Grid.Row="1" MaxHeight="215" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="FontAssetList"
                                                      ItemsSource="{Binding FontAssets}"
                                                      Visibility="Collapsed">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,0,0,1" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="66" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="74" />
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="80" />
                                                            </Grid.ColumnDefinitions>
                                                            <!-- 字体源名称 -->
                                                            <TextBlock Text="{Binding SourceId, Converter={StaticResource SourceIdToFontNameConverter}}"
                                                                       FontSize="10" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <!-- 文件名 -->
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <!-- 导出格式 -->
                                                            <TextBlock Grid.Column="4"
                                                                    Text="{Binding ExportFormat}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" FontSize="10"
                                                                    Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <!-- 字号 -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Size, StringFormat='{}{0}px'}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <!-- 位深 -->
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding Bpp, StringFormat='{}{0}bpp'}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                           
                                                            <!-- 字形（截断显示，点击编辑） -->
                                                            <TextBlock Grid.Column="5"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       FontSize="13"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Cursor="Hand"
                                                                       MouseLeftButtonDown="BtnEditGlyphs_Click"
                                                                       ToolTip="点击编辑字形字符">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Glyphs" />
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                            <!-- 操作按钮 -->
                                                            <StackPanel Grid.Column="6"
                                                                        Orientation="Horizontal"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                <Button Content="生成" FontSize="11"
                                                                        Padding="6,2" Margin="0,0,4,0"
                                                                        Click="BtnGenerateFont_Click"
                                                                        Cursor="Hand" />
                                                                <Button Content="✕" FontSize="11"
                                                                        Padding="6,2"
                                                                        Click="BtnDeleteFont_Click"
                                                                        Cursor="Hand"
                                                                        Foreground="{DynamicResource TextMutedBrush}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <!-- 分页器（有数据时显示） -->
                                    <Border Grid.Row="2" Visibility="Collapsed"
                                            x:Name="FontPager" Margin="0,8,0,0">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="显示" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox x:Name="CmbFontPageSize" Width="52" FontSize="11" Margin="4,0" SelectedIndex="0"
                                                          SelectionChanged="CmbFontPageSize_SelectionChanged">
                                                    <ComboBoxItem Content="5" />
                                                    <ComboBoxItem Content="10" />
                                                    <ComboBoxItem Content="15" />
                                                    <ComboBoxItem Content="20" />
                                                </ComboBox>
                                                <TextBlock Text="条/页" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button x:Name="BtnFontPrev" Content="◀" Width="28" Height="24" Padding="0" FontSize="10"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Cursor="Hand" IsEnabled="False"
                                                        Click="BtnFontPrev_Click" />
                                                <TextBlock x:Name="TxtFontPageInfo" Text="第 1/1 页" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="8,0" />
                                                <Button x:Name="BtnFontNext" Content="▶" Width="28" Height="24" Padding="0" FontSize="10"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Cursor="Hand" IsEnabled="False"
                                                        Click="BtnFontNext_Click" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- 图片资产 -->
                            <Border Grid.Row="2"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" Padding="16 0 16 0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- 标题栏 -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                        <Button x:Name="BtnCreateImage"
                                                Content="➕ 创建图片"
                                                Style="{StaticResource PrimaryButton}"
                                                DockPanel.Dock="Right"
                                                Click="BtnCreateImage_Click" />
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="项目图片资产" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock x:Name="TxtImageAssetCount"
                                                       Text="{Binding ImageAssetCount}" FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="8,0,0,0" />
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- 表格 -->
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- 表头 -->
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource SecondaryBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1" Padding="8,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="74" />
                                                    <ColumnDefinition Width="80" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="预览" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                                <TextBlock Grid.Column="1" Text="文件" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           Margin="6,0,0,0" />
                                                <TextBlock Grid.Column="2" Text="尺寸" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="像素" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="导出格式" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="操作" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <!-- 空状态 -->
                                        <StackPanel x:Name="ImageEmptyState" Grid.Row="1"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="⚠ 暂无图片资产" FontSize="14"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Text="点击「创建图片」从资源库生成图片.c文件" FontSize="12"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       HorizontalAlignment="Center" Margin="0,6,0,0" />
                                        </StackPanel>

                                        <!-- 数据行容器（有数据时显示） -->
                                        <ScrollViewer Grid.Row="1" MaxHeight="172" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="ImageAssetList"
                                                      ItemsSource="{Binding ImageAssets}"
                                                      Visibility="Collapsed">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="0,0,0,1" Padding="8,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="74" />
                                                                <ColumnDefinition Width="80" />
                                                            </Grid.ColumnDefinitions>
                                                            <!-- 图片预览：加载成功显示缩略图，失败显示 🖼 -->
                                                            <Grid>
                                                                <TextBlock x:Name="ImgFallback" Text="🖼" FontSize="16"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Visibility="Collapsed" />
                                                                <Image x:Name="ImgPreview"
                                                                       Source="{Binding SourceId, Converter={StaticResource SourceIdToImageConverter}}"
                                                                       MaxWidth="56" MaxHeight="32" Stretch="Uniform"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Grid>
                                                            <!-- 文件名 -->
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                       VerticalAlignment="Center" Margin="6,0,0,0"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <!-- 尺寸 -->
                                                            <TextBlock Grid.Column="2"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="12"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}">
                                                                <Run Text="{Binding Width, Mode=OneWay}" />
                                                                <Run Text="×" />
                                                                <Run Text="{Binding Height, Mode=OneWay}" />
                                                            </TextBlock>
                                                            <!-- 像素格式 -->
                                                            <TextBlock Grid.Column="3"
                                                                       Text="{Binding Format}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="11"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <!-- 导出格式 -->
                                                            <TextBlock Grid.Column="4"
                                                                       Text="{Binding ExportFormat}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <!-- 操作按钮 -->
                                                            <StackPanel Grid.Column="5"
                                                                        Orientation="Horizontal"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center">
                                                                <Button Content="生成" FontSize="11"
                                                                        Padding="6,2" Margin="0,0,4,0"
                                                                        Click="BtnGenerateImage_Click"
                                                                        Cursor="Hand" />
                                                                <Button Content="✕" FontSize="11"
                                                                        Padding="6,2"
                                                                        Click="BtnDeleteImage_Click"
                                                                        Cursor="Hand"
                                                                        Foreground="{DynamicResource TextMutedBrush}" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Source, ElementName=ImgPreview}" Value="{x:Null}">
                                                            <Setter TargetName="ImgPreview" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="ImgFallback" Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>

                                    <!-- 分页器 -->
                                    <Border Grid.Row="2" Visibility="Collapsed"
                                            x:Name="ImagePager" Margin="0,8,0,0">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="显示" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                                <ComboBox x:Name="CmbImagePageSize" Width="52" FontSize="11" Margin="4,0" SelectedIndex="0"
                                                          SelectionChanged="CmbImagePageSize_SelectionChanged">
                                                    <ComboBoxItem Content="5" />
                                                    <ComboBoxItem Content="10" />
                                                    <ComboBoxItem Content="15" />
                                                    <ComboBoxItem Content="20" />
                                                </ComboBox>
                                                <TextBlock Text="条/页" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button x:Name="BtnImagePrev" Content="◀" Width="28" Height="24" Padding="0" FontSize="10"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Cursor="Hand" IsEnabled="False"
                                                        Click="BtnImagePrev_Click" />
                                                <TextBlock x:Name="TxtImagePageInfo" Text="第 1/1 页" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" Margin="8,0" />
                                                <Button x:Name="BtnImageNext" Content="▶" Width="28" Height="24" Padding="0" FontSize="10"
                                                        Background="Transparent" BorderThickness="0"
                                                        Foreground="{DynamicResource TextMutedBrush}"
                                                        Cursor="Hand" IsEnabled="False"
                                                        Click="BtnImageNext_Click" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- 底部状态栏 -->
            <Border Grid.Row="2"
                    Background="{DynamicResource SecondaryBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,6">
                <DockPanel>
                    <!-- 右侧：项目统计 -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatusProject"
                                   Text="{Binding SelectedProject, FallbackValue='——'}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text=" · " FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="TxtStatusStats"
                                   Text="{Binding StatusStats}" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- 左侧：状态文字 -->
                    <TextBlock x:Name="TxtStatus"
                               Text="{Binding StatusText}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== 对话框遮罩层（初始隐藏） ===== -->
        <Grid x:Name="Overlay"
              Visibility="Collapsed"
              Background="#88000000"
              MouseDown="Overlay_MouseDown">
            <Border x:Name="DialogContainer"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MouseDown="DialogContainer_MouseDown" />
        </Grid>
    </Grid>
</Window>
